{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tsukumogami/koto/pkg/template/compiled-template.schema.json",
  "title": "Koto Compiled Template",
  "description": "JSON schema for koto compiled workflow templates (format_version 1).",
  "type": "object",
  "required": ["format_version", "name", "version", "initial_state", "states"],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version for the compiled template format."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Name of the workflow template."
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "description": "Version of the workflow template."
    },
    "description": {
      "type": "string",
      "description": "Human-readable description of the workflow."
    },
    "initial_state": {
      "type": "string",
      "minLength": 1,
      "description": "Name of the starting state. Must reference a key in states."
    },
    "variables": {
      "type": "object",
      "description": "Variable declarations for the workflow.",
      "additionalProperties": {
        "$ref": "#/$defs/variable_decl"
      }
    },
    "states": {
      "type": "object",
      "minProperties": 1,
      "description": "State definitions keyed by state name.",
      "additionalProperties": {
        "$ref": "#/$defs/state_decl"
      }
    }
  },
  "$defs": {
    "variable_decl": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string",
          "description": "Human-readable description of the variable."
        },
        "required": {
          "type": "boolean",
          "description": "Whether this variable must be provided at workflow creation."
        },
        "default": {
          "type": "string",
          "description": "Default value if not provided."
        }
      }
    },
    "state_decl": {
      "type": "object",
      "required": ["directive"],
      "additionalProperties": false,
      "properties": {
        "directive": {
          "type": "string",
          "minLength": 1,
          "description": "Instruction text for the agent in this state."
        },
        "transitions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Allowed target state names for transitions from this state."
        },
        "terminal": {
          "type": "boolean",
          "description": "Whether this is a terminal (end) state."
        },
        "gates": {
          "type": "object",
          "description": "Precondition gates keyed by gate name.",
          "additionalProperties": {
            "$ref": "#/$defs/gate_decl"
          }
        }
      }
    },
    "gate_decl": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["field_not_empty", "field_equals", "command"],
          "description": "Gate type determining validation behavior."
        },
        "field": {
          "type": "string",
          "description": "Variable name to check (required for field_not_empty and field_equals)."
        },
        "value": {
          "type": "string",
          "description": "Expected value for field_equals gates."
        },
        "command": {
          "type": "string",
          "description": "Shell command to execute for command gates."
        },
        "timeout": {
          "type": "integer",
          "minimum": 0,
          "description": "Timeout in seconds for command gates. 0 means default (30s)."
        }
      }
    }
  }
}
