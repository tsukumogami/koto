#!/bin/sh
# A hook script to format Rust code before committing.
# If any Rust files are staged, runs cargo fmt on them and re-stages the changes.

# Get the list of staged Rust files
RS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.rs$')

# Exit if no Rust files are staged
if [ -z "$RS_FILES" ]; then
    exit 0
fi

# Format all Rust code (cargo fmt doesn't accept individual files easily)
cargo fmt

# Re-add the formatted files to the staging area
echo "$RS_FILES" | xargs git add

exit 0
